# SAM.gov Contract Opportunities API (Public Get Opportunities v2)
# Get your key at: https://sam.gov (Account Details -> API Key)
# Copy this file to .env.local and set your key.
SAM_GOV_API_KEY=your-sam-gov-api-key

# Backend API URL (Python Flask server)
# Local development: http://localhost:9000
# Production (Render): https://backendgovai.onrender.com
BACKEND_URL=https://backendgovai.onrender.com
